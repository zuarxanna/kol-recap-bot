# Copy this file to .env and fill in the real values. Do NOT commit .env.
# Apify Console -> Settings -> API & Integrations -> Personal API tokens
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# Telegram bot (node dist/src/index.js). Get the token from BotFather.
TELEGRAM_BOT_TOKEN=123456:abcdef...
# HARD ALLOWLIST — allowed user ids (comma-separated). Without this the bot refuses to start.
# Find your id: message @userinfobot on Telegram.
TELEGRAM_ALLOWED_IDS=123456789

# YouTube (optional — if set, YouTube is auto-scraped; if empty, YouTube is skipped).
# FREE: console.cloud.google.com -> enable "YouTube Data API v3" -> Credentials -> API key.
# Quota is 10,000 units/day (not a bill). Our usage is ~3-5 units/KOL.
YOUTUBE_API_KEY=
