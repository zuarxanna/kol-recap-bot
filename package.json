{
  "name": "kol-recap-bot",
  "version": "0.0.1",
  "description": "KOL metrics recap — Telegram bot + Apify + YouTube Data API, local JSON storage",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "recap": "tsx src/recap/builder/recap.ts",
    "bot": "tsx src/index.ts",
    "recap:prod": "node dist/src/recap/builder/recap.js",
    "bot:prod": "node dist/src/index.js",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "apify-client": "^2.9.3",
    "dotenv": "^17.4.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
